<Window x:Class="GetDownloadedDumbass.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GetDownloadedDumbass.ViewModels"
        Title="GetDownloadedDumbass" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Gradient brush -->
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFB300" Offset="0"/>
            <GradientStop Color="#FF4500" Offset="0.5"/>
            <GradientStop Color="#8B0030" Offset="1"/>
        </LinearGradientBrush>

        <!-- Button style -->
        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{StaticResource AccentGradient}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox style sombre complet -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="10,6"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,6,24,6"
                                              VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" CornerRadius="6">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#1A1A1A"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FF4500"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Background="{StaticResource AccentGradient}">
            <TextBlock Text="GET DOWNLOADED DUMBASS"
                       Foreground="White" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="20,0"/>
        </Border>

        <!-- ── MAIN CONTENT ── -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="160"/>
                </Grid.RowDefinitions>

                <!-- URL input row -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                             Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0"/>

                    <ComboBox Grid.Column="1" Width="90" Margin="0,0,8,0"
                              Style="{StaticResource DarkCombo}"
                              ItemsSource="{Binding Formats}"
                              SelectedItem="{Binding SelectedFormat}"/>

                    <ComboBox Grid.Column="2" Width="100" Margin="0,0,8,0"
                              Style="{StaticResource DarkCombo}"
                              ItemsSource="{Binding Qualities}"
                              SelectedItem="{Binding SelectedQuality}"/>

                    <Button Grid.Column="3" Content="+ Add"
                            Style="{StaticResource GradientButton}"
                            Command="{Binding AddToQueueCommand}"/>
                </Grid>

                <!-- Queue list -->
                <Border Grid.Row="1" Background="#111" CornerRadius="8" Margin="0,0,0,12">
                    <Grid>
                        <TextBlock Text="QUEUE" Foreground="#555" FontSize="11" FontWeight="Bold"
                                   Margin="12,8" VerticalAlignment="Top"/>
                        <ListBox ItemsSource="{Binding Queue}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" Margin="0,28,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Url}"
                                                   Foreground="#CCC" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Format}"
                                                   Foreground="#FF6B00" FontSize="11"
                                                   Margin="8,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Quality}"
                                                   Foreground="#888" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Text="Queue is empty — paste a URL above"
                                   Foreground="#333" FontSize="12" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,28,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Queue.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- History label + clear -->
                <Grid Grid.Row="2" Margin="0,0,0,6">
                    <TextBlock Text="HISTORY" Foreground="#555" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="Clear" HorizontalAlignment="Right"
                            Style="{StaticResource GradientButton}"
                            FontSize="11" Padding="10,4"
                            Command="{Binding ClearHistoryCommand}"/>
                </Grid>

                <!-- History list -->
                <Border Grid.Row="3" Background="#111" CornerRadius="8">
                    <ListBox ItemsSource="{Binding History}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Url}"
                                               Foreground="#AAA" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Status}"
                                               Foreground="#FF6B00" FontSize="11"
                                               Margin="8,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- RIGHT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Button Grid.Row="0" Content="▶  START DOWNLOAD"
                    Style="{StaticResource GradientButton}"
                    FontSize="15" Padding="0,16"
                    Command="{Binding StartDownloadCommand}"
                    Margin="0,0,0,8"/>

                <Button Grid.Row="1" Content="⏹  STOP"
                        Style="{StaticResource GradientButton}"
                        FontSize="15" Padding="0,12"
                        Command="{Binding StopDownloadCommand}"
                        Margin="0,0,0,16"/>
                <Border Grid.Row="1" Background="#111" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="OUTPUT FOLDER" Foreground="#555" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Settings.DefaultOutputFolder}"
                                   Foreground="#CCC" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Button Content="Browse…" Style="{StaticResource GradientButton}"
                                FontSize="12" Padding="0,8"
                                Command="{Binding BrowseFolderCommand}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#111" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="STATUS" Foreground="#555" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ProgressBar IsIndeterminate="{Binding IsBusy}"
                                     Height="6" Background="#222"
                                     Margin="0,0,0,8">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFB300" Offset="0"/>
                                    <GradientStop Color="#FF4500" Offset="1"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#CCC" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ── STATUS BAR ── -->
        <Border Grid.Row="2" Background="#111">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#666" FontSize="11"
                       VerticalAlignment="Center" Margin="16,0"/>
        </Border>
    </Grid>
</Window>