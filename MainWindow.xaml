<Window x:Class="GetDownloadedDumbass.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GetDownloadedDumbass.ViewModels"
        Title="GetDownloadedDumbass" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>

        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFB300" Offset="0"/>
            <GradientStop Color="#FF4500" Offset="0.5"/>
            <GradientStop Color="#8B0030" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="{StaticResource AccentGradient}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="16,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FF4500"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="Transparent"
                                BorderBrush="#FF4500"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="16,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFF4500"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="#FF4500"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="14,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF4500"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#141414" BorderBrush="#2A2A2A"
                                                BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="14,10"/>
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 5 5 L 10 0 Z"
                                                      Fill="#FF4500"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="14,10,32,10"
                                              VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                <Border Background="#1A1A1A" BorderBrush="#2A2A2A"
                                        BorderThickness="1" CornerRadius="8"
                                        Margin="0,4,0,0">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="14,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1AFF4500"/>
                                            <Setter Property="Foreground" Value="#FF4500"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="CleanListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="0,2">
                            <ContentPresenter Margin="10,8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0FFF4500"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFF4500"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GradientProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FFB300" Offset="0"/>
                                            <GradientStop Color="#FF4500" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource AccentGradient}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GDD" FontSize="22" FontWeight="Black"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Border Width="1" Background="#40FFFFFF" Margin="14,8"/>
                    <TextBlock Text="Get Downloaded Dumbass"
                               FontSize="12" Foreground="#CCFFFFFF"
                               VerticalAlignment="Center" FontWeight="Light"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding Queue.Count, StringFormat='{}{0} in queue'}"
                           Foreground="#80FFFFFF" FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>
                    <ComboBox Grid.Column="2"
                              Style="{StaticResource DarkCombo}"
                              ItemsSource="{Binding Formats}"
                              SelectedItem="{Binding SelectedFormat}"/>
                    <ComboBox Grid.Column="4"
                              Style="{StaticResource DarkCombo}"
                              ItemsSource="{Binding Qualities}"
                              SelectedItem="{Binding SelectedQuality}"/>
                    <Button Grid.Column="6"
                            Content="+ ADD TO QUEUE"
                            Style="{StaticResource GradientButton}"
                            Command="{Binding AddToQueueCommand}"/>
                </Grid>

                <Border Grid.Row="2" Background="#0F0F0F"
                        BorderBrush="#1E1E1E" BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="16,12,16,10"
                                BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="3" Height="14" CornerRadius="2" Margin="0,0,10,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFB300" Offset="0"/>
                                            <GradientStop Color="#FF4500" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="QUEUE"
                                           Foreground="#666" FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <Border Background="#1AFF4500" CornerRadius="10"
                                        Padding="8,2" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Queue.Count}"
                                               Foreground="#FF4500" FontSize="10"
                                               FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1">
                            <TextBlock Text="Queue is empty — paste a URL above"
                                       Foreground="#2A2A2A" FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Queue.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ListBox ItemsSource="{Binding Queue}"
                                     Style="{StaticResource CleanListBox}"
                                     ItemContainerStyle="{StaticResource CleanListBoxItem}"
                                     Margin="8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Url}"
                                                       Foreground="#AAA" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1"
                                                    Background="#1AFF6B00" CornerRadius="4"
                                                    Padding="6,2" Margin="8,0,6,0">
                                                <TextBlock Text="{Binding Format}"
                                                           Foreground="#FF6B00" FontSize="10"
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Quality}"
                                                       Foreground="#555" FontSize="11"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="3" Height="14" CornerRadius="2" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFB300" Offset="0"/>
                                    <GradientStop Color="#FF4500" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="HISTORY" Foreground="#666"
                                   FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="CLEAR" HorizontalAlignment="Right"
                            Style="{StaticResource GhostButton}"
                            FontSize="10" Padding="10,4"
                            Command="{Binding ClearHistoryCommand}"/>
                </Grid>

                <Border Grid.Row="6" Background="#0F0F0F"
                        BorderBrush="#1E1E1E" BorderThickness="1"
                        CornerRadius="12">
                    <ListBox ItemsSource="{Binding History}"
                             Style="{StaticResource CleanListBox}"
                             ItemContainerStyle="{StaticResource CleanListBoxItem}"
                             Margin="8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Url}"
                                               Foreground="#555" FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" CornerRadius="4"
                                            Padding="6,2" Margin="8,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A4CAF50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Background" Value="#1AF44336"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Content="START DOWNLOAD"
                        Style="{StaticResource GradientButton}"
                        FontSize="14" Padding="0,18"
                        Command="{Binding StartDownloadCommand}"/>

                <Button Grid.Row="2"
                        Content="STOP"
                        Style="{StaticResource GhostButton}"
                        FontSize="13" Padding="0,12"
                        Command="{Binding StopDownloadCommand}"/>

                <Border Grid.Row="4" Background="#0F0F0F"
                        BorderBrush="#1E1E1E" BorderThickness="1"
                        CornerRadius="12" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="3" Height="14" CornerRadius="2" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFB300" Offset="0"/>
                                        <GradientStop Color="#FF4500" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="OUTPUT FOLDER"
                                       Foreground="#666" FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Settings.DefaultOutputFolder}"
                                   Foreground="#777" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,12"
                                   MaxHeight="40"/>
                        <Button Content="Browse"
                                Style="{StaticResource GradientButton}"
                                FontSize="12" Padding="0,10"
                                Command="{Binding BrowseFolderCommand}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="6" Background="#0F0F0F"
                        BorderBrush="#1E1E1E" BorderThickness="1"
                        CornerRadius="12" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="3" Height="14" CornerRadius="2" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFB300" Offset="0"/>
                                        <GradientStop Color="#FF4500" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="STATUS"
                                       Foreground="#666" FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ProgressBar Style="{StaticResource GradientProgress}"
                                     IsIndeterminate="{Binding IsBusy}"
                                     Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#888" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#080808"
                BorderBrush="#1A1A1A" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#333" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Text="GDD v1.0"
                           Foreground="#222" FontSize="11"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>